# ============================================
# OTAKUDESU API - Environment Variables
# ============================================
# Copy file ini ke .env dan sesuaikan konfigurasi

# --------------------------------------------
# Server Configuration
# --------------------------------------------
PORT=3000
NODE_ENV=development

# --------------------------------------------
# Otakudesu Base URL
# --------------------------------------------
BASE_URL=https://otakudesu.best

# --------------------------------------------
# Cache TTL (in seconds)
# --------------------------------------------
# Latest anime: 5 menit
CACHE_TTL_LATEST=300

# Detail anime: 10 menit
CACHE_TTL_ANIME=600

# Search: 3 menit
CACHE_TTL_SEARCH=180

# --------------------------------------------
# Rate Limiting
# --------------------------------------------
# 15 menit window
RATE_LIMIT_WINDOW_MS=900000

# Max 60 requests per window
RATE_LIMIT_MAX_REQUESTS=60

# --------------------------------------------
# Request Delay (ms)
# --------------------------------------------
# Delay 1-3 detik agar tidak terdeteksi bot
REQUEST_DELAY_MIN=1000
REQUEST_DELAY_MAX=3000

# --------------------------------------------
# Puppeteer Options
# --------------------------------------------
PUPPETEER_HEADLESS=true
PUPPETEER_TIMEOUT=30000

# --------------------------------------------
# Vercel Configuration (Optional)
# --------------------------------------------
# Set ke "1" jika deploy di Vercel
# VERCEL=1
